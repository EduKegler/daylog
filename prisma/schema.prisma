generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── NextAuth Models ───────────────────────────

model User {
  id                String    @id @default(cuid())
  name              String?
  email             String?   @unique
  emailVerified     DateTime?
  image             String?
  timezone          String    @default("America/Sao_Paulo")
  lastProcessedDate DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  recurringTasks RecurringTask[]
  dailyTasks     DailyTask[]
  tags           Tag[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Guest Sessions ──────────────────────────────

model GuestSession {
  id                String    @id @default(cuid())
  timezone          String    @default("America/Sao_Paulo")
  lastProcessedDate DateTime?
  expiresAt         DateTime
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  recurringTasks RecurringTask[]
  dailyTasks     DailyTask[]
  tags           Tag[]
}

// ─── Domain Models ─────────────────────────────

enum RecurrenceType {
  DAILY
  WEEKDAYS
  SPECIFIC_WEEKDAYS
  MONTHLY
}

enum SourceType {
  RECURRING
  MANUAL
}

enum TaskStatus {
  PENDING
  COMPLETED
  SKIPPED
  DISMISSED
}

model RecurringTask {
  id               String         @id @default(cuid())
  userId           String?
  guestSessionId   String?
  title            String
  description      String?
  recurrenceType   RecurrenceType
  recurrenceConfig String?
  isActive         Boolean        @default(true)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  user         User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  dailyTasks   DailyTask[]
  tags         Tag[]

  @@index([userId, isActive])
  @@index([guestSessionId, isActive])
}

model DailyTask {
  id              String     @id @default(cuid())
  userId          String?
  guestSessionId  String?
  sourceType      SourceType
  recurringTaskId String?
  title           String
  description     String?
  scheduledDate   DateTime
  status          TaskStatus @default(PENDING)
  completedAt     DateTime?
  originalDate    DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  user          User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession  GuestSession?  @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  recurringTask RecurringTask? @relation(fields: [recurringTaskId], references: [id], onDelete: SetNull)
  tags          Tag[]

  @@index([userId, scheduledDate])
  @@index([guestSessionId, scheduledDate])
  @@unique([recurringTaskId, scheduledDate])
}

model Tag {
  id             String   @id @default(cuid())
  userId         String?
  guestSessionId String?
  name           String
  color          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user           User?         @relation(fields: [userId], references: [id], onDelete: Cascade)
  guestSession   GuestSession? @relation(fields: [guestSessionId], references: [id], onDelete: Cascade)
  dailyTasks     DailyTask[]
  recurringTasks RecurringTask[]

  @@index([userId])
  @@index([guestSessionId])
}
